        "test": "jest"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.5.0",
        "typescript": "^5.0.0",
        "webpack": "^5.0.0",
        "webpack-cli": "^5.0.0"
    }
}