{
    "name": "janitor-ai-eval",
    "version": "0.1.0-beta",
    "description": "Standalone custom AST javascript evaluator and snippet for the Janitor AI environment",
    "main": "dist/bundle.js",
    "scripts": {
        "clean": "rm -rf dist",
        "build": "webpack --config webpack.config.js && node patch-bundle.js",
